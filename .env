# ============================================================
# VFS Global Appointment Monitor - Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- VFS Account Credentials ---
# Your VFS Global login email and password (the account you use to book)
VFS_EMAIL=zenduozs@gmail.com
VFS_PASSWORD=

# --- VFS Appointment Parameters ---
# The country you are applying FROM (e.g., "dza" for Algeria, "mar" for Morocco,
# "ind" for India, "pak" for Pakistan, "tur" for Turkey, "nga" for Nigeria)
VFS_COUNTRY_CODE=dza

# The country you are applying TO (e.g., "fra" for France, "deu" for Germany,
# "ita" for Italy, "esp" for Spain, "gbr" for UK, "can" for Canada)
VFS_MISSION_CODE=ita

# VFS Center/City code (e.g., "ALG" for Algiers, "ORN" for Oran)
# You can find this by inspecting the VFS booking page or app network traffic
VFS_CENTER_CODE=ALG

# Visa category code (e.g., "SCH" for Schengen, "NTV" for National Visa)
# Check VFS website for your specific category
VFS_VISA_CATEGORY=BUS

# Visa subcategory (e.g., "STV" for Short-term Visa, "LTV" for Long-term Visa)
# Leave empty if not applicable
VFS_VISA_SUBCATEGORY=TOUR

# --- Monitoring Settings ---
# How often to check for appointments (in seconds). Default: 180 (3 minutes)
# Be reasonable — too aggressive and VFS may block you.
CHECK_INTERVAL_SECONDS=180

# --- Telegram Notifications ---
# 1. Create a bot: message @BotFather on Telegram, send /newbot, follow prompts
# 2. Copy the bot token here
# 3. Start a chat with your bot, then visit:
#    https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#    to find your chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
